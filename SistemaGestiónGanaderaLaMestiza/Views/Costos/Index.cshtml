@{
    ViewBag.Title = "Costos";
    var costos = ViewBag.Costos as System.Collections.Generic.IList<SistemaGestiónGanaderaLaMestiza.Models.Costo>;
    var animales = ViewBag.Animales as System.Collections.Generic.IList<SistemaGestiónGanaderaLaMestiza.Models.Animal>;
}
<div class="page-header">
    <div>
        <h2 class="mb-1">Control de costos</h2>
        <p class="text-muted mb-0">Registra gastos y consulta el historial por animal y periodo.</p>
    </div>
</div>

<div class="surface-card mb-3">
    <h3 class="section-title">Registrar costo</h3>
    @using (Html.BeginForm("Registrar", "Costos", FormMethod.Post))
    {
        @Html.AntiForgeryToken()
        <div class="filter-grid">
            <select name="id_animal" class="form-select" required>
                <option value="">Animal</option>
                @if (animales != null)
                {
                    foreach (var a in animales)
                    {
                        <option value="@a.IdAnimal">@a.Nombre</option>
                    }
                }
            </select>
            <input type="number" name="monto" class="form-control" placeholder="Monto" step="0.01" min="0" required />
        </div>
        <div class="mt-3">
            <button type="submit" class="btn btn-primary">Registrar costo</button>
        </div>
    }
</div>

<div class="surface-card mb-3">
    <h3 class="section-title">Filtros</h3>
    @using (Html.BeginForm("Index", "Costos", FormMethod.Get))
    {
        <div class="filter-grid">
            <select name="id_animal" class="form-select form-select-sm">
                <option value="">Todos los animales</option>
                @if (animales != null)
                {
                    foreach (var a in animales)
                    {
                        <option value="@a.IdAnimal" @(Request.QueryString["id_animal"] == a.IdAnimal.ToString() ? "selected" : "")>@a.Nombre</option>
                    }
                }
            </select>
            <input type="date" name="desde" class="form-control form-control-sm" value="@Request.QueryString["desde"]" />
            <input type="date" name="hasta" class="form-control form-control-sm" value="@Request.QueryString["hasta"]" />
        </div>
        <div class="mt-3 d-flex gap-2">
            <button type="submit" class="btn btn-sm btn-secondary">Filtrar</button>
            <a href="@Url.Action("Index", "Costos")" class="btn btn-sm btn-outline-secondary">Limpiar</a>
        </div>
    }
</div>

<div class="surface-card table-card">
    <div class="table-responsive">
        <table class="table table-hover">
            <thead><tr><th>Animal</th><th>Monto</th><th>Fecha</th></tr></thead>
            <tbody>
                @if (costos != null && costos.Count > 0)
                {
                    foreach (var c in costos)
                    {
                        <tr><td>@c.NombreAnimal</td><td>@(c.Monto?.ToString("N2"))</td><td>@(c.FechaCosto?.ToString("yyyy-MM-dd"))</td></tr>
                    }
                }
                else
                {
                    <tr><td colspan="3" class="text-center text-muted py-4">No hay costos registrados para los filtros seleccionados.</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>
