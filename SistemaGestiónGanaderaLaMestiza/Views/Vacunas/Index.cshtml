@{
    ViewBag.Title = "Vacunas";
    var vacunas = ViewBag.Vacunas as System.Collections.Generic.IList<SistemaGestiónGanaderaLaMestiza.Models.Vacuna>;
    var historial = ViewBag.Historial as System.Collections.Generic.IList<SistemaGestiónGanaderaLaMestiza.Models.VacunacionHistorialItem>;
    var animales = ViewBag.Animales as System.Collections.Generic.IList<SistemaGestiónGanaderaLaMestiza.Models.Animal>;
}
<div class="page-header">
    <div>
        <h2 class="mb-1">Control de vacunas</h2>
        <p class="text-muted mb-0">Registra aplicaciones y consulta historial reciente.</p>
    </div>
</div>

<div class="surface-card mb-3">
    <h3 class="section-title">Registrar vacunacion</h3>
    @using (Html.BeginForm("Registrar", "Vacunas", FormMethod.Post))
    {
        @Html.AntiForgeryToken()
        <div class="filter-grid">
            <div>
                <label class="form-label">Animal</label>
                <select name="id_animal" class="form-select" required>
                    <option value="">Seleccione</option>
                    @if (animales != null)
                    {
                        foreach (var a in animales)
                        {
                            <option value="@a.IdAnimal">@a.Nombre</option>
                        }
                    }
                </select>
            </div>
            <div>
                <label class="form-label">Vacuna</label>
                <select name="id_vacuna" class="form-select" required>
                    <option value="">Seleccione</option>
                    @if (vacunas != null)
                    {
                        foreach (var v in vacunas)
                        {
                            <option value="@v.IdVacuna">@v.Nombre</option>
                        }
                    }
                </select>
            </div>
            <div>
                <label class="form-label">Fecha</label>
                <input type="date" name="fecha_aplicacion" class="form-control" />
            </div>
        </div>
        <div class="mt-3">
            <button type="submit" class="btn btn-primary">Registrar vacunacion</button>
        </div>
    }
</div>

<div class="surface-card table-card">
    <h3 class="section-title">Historial reciente</h3>
    <div class="table-responsive">
        <table class="table table-hover">
            <thead><tr><th>Animal</th><th>Vacuna</th><th>Fecha</th></tr></thead>
            <tbody>
                @if (historial != null && historial.Count > 0)
                {
                    foreach (var h in historial)
                    {
                        <tr><td>@h.NombreAnimal</td><td>@h.NombreVacuna</td><td>@(h.FechaAplicacion?.ToString("yyyy-MM-dd"))</td></tr>
                    }
                }
                else
                {
                    <tr><td colspan="3" class="text-center text-muted py-4">No hay vacunaciones registradas.</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>
