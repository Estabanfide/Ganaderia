@{
    ViewBag.Title = "Registro";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<div class="auth-wrapper">
    <div class="card auth-card">
        <div class="card-body">
            <h2 class="mb-1">Crear cuenta</h2>
            <p class="text-muted mb-4">Registra un usuario para comenzar a gestionar la finca.</p>
            @using (Html.BeginForm("Register", "Auth", FormMethod.Post))
            {
                @Html.AntiForgeryToken()
                <div class="mb-3">
                    <label class="form-label">Nombre completo</label>
                    <input type="text" name="nombre" class="form-control" required />
                </div>
                <div class="mb-3">
                    <label class="form-label">Correo electronico</label>
                    <input type="email" name="email" class="form-control" required />
                </div>
                <div class="mb-4">
                    <label class="form-label">Contrasena</label>
                    <input type="password" name="password" class="form-control" required />
                </div>
                <button type="submit" class="btn btn-primary w-100">Crear cuenta</button>
            }
            <p class="mt-3 mb-0 text-center">Ya tienes cuenta? @Html.ActionLink("Inicia sesion", "Login", "Auth")</p>
        </div>
    </div>
</div>
