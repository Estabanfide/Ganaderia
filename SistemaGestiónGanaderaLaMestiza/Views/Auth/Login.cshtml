@{
    ViewBag.Title = "Iniciar sesión";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<div class="auth-wrapper">
    <div class="card auth-card">
        <div class="card-body">
            <h2 class="mb-1">Bienvenido</h2>
            <p class="text-muted mb-4">Inicia sesion para administrar tu operacion ganadera.</p>
            @using (Html.BeginForm("Login", "Auth", FormMethod.Post))
            {
                @Html.AntiForgeryToken()
                <div class="mb-3">
                    <label class="form-label">Correo electronico</label>
                    <input type="email" name="email" class="form-control" required />
                </div>
                <div class="mb-4">
                    <label class="form-label">Contrasena</label>
                    <input type="password" name="password" class="form-control" required />
                </div>
                <button type="submit" class="btn btn-primary w-100">Entrar al sistema</button>
            }
            <p class="mt-3 mb-0 text-center">No tienes cuenta? @Html.ActionLink("Registrate", "Register", "Auth")</p>
        </div>
    </div>
</div>
