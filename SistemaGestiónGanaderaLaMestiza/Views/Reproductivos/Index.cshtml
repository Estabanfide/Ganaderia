@{
    ViewBag.Title = "Eventos reproductivos";
    var eventos = ViewBag.Eventos as System.Collections.Generic.IList<SistemaGestiónGanaderaLaMestiza.Models.EventoReproductivo>;
    var animales = ViewBag.Animales as System.Collections.Generic.IList<SistemaGestiónGanaderaLaMestiza.Models.Animal>;
}
<div class="page-header">
    <div>
        <h2 class="mb-1">Eventos reproductivos</h2>
        <p class="text-muted mb-0">Registra monta, parto y otros eventos reproductivos.</p>
    </div>
</div>

<div class="surface-card mb-3">
    <h3 class="section-title">Registrar evento</h3>
    @using (Html.BeginForm("Registrar", "Reproductivos", FormMethod.Post))
    {
        @Html.AntiForgeryToken()
        <div class="filter-grid">
            <select name="id_animal" class="form-select" required>
                <option value="">Animal</option>
                @if (animales != null)
                {
                    foreach (var a in animales)
                    {
                        <option value="@a.IdAnimal">@a.Nombre</option>
                    }
                }
            </select>
            <input type="date" name="fecha_evento" class="form-control" />
            <input type="text" name="tipo_evento" class="form-control" placeholder="Tipo (ej. Monta, Parto)" />
        </div>
        <div class="mt-3">
            <button type="submit" class="btn btn-primary">Registrar evento</button>
        </div>
    }
</div>

<div class="surface-card mb-3">
    <h3 class="section-title">Filtros</h3>
    @using (Html.BeginForm("Index", "Reproductivos", FormMethod.Get))
    {
        <div class="filter-grid">
            <select name="id_animal" class="form-select form-select-sm">
                <option value="">Todos</option>
                @if (animales != null)
                {
                    foreach (var a in animales)
                    {
                        <option value="@a.IdAnimal" @(Request.QueryString["id_animal"] == a.IdAnimal.ToString() ? "selected" : "")>@a.Nombre</option>
                    }
                }
            </select>
            <input type="date" name="desde" class="form-control form-control-sm" value="@Request.QueryString["desde"]" />
            <input type="date" name="hasta" class="form-control form-control-sm" value="@Request.QueryString["hasta"]" />
        </div>
        <div class="mt-3 d-flex gap-2">
            <button type="submit" class="btn btn-sm btn-secondary">Filtrar</button>
            <a href="@Url.Action("Index", "Reproductivos")" class="btn btn-sm btn-outline-secondary">Limpiar</a>
        </div>
    }
</div>

<div class="surface-card table-card">
    <div class="table-responsive">
        <table class="table table-hover">
            <thead><tr><th>Animal</th><th>Fecha</th><th>Tipo</th></tr></thead>
            <tbody>
                @if (eventos != null && eventos.Count > 0)
                {
                    foreach (var e in eventos)
                    {
                        <tr><td>@e.NombreAnimal</td><td>@(e.FechaEvento?.ToString("yyyy-MM-dd"))</td><td>@e.TipoEvento</td></tr>
                    }
                }
                else
                {
                    <tr><td colspan="3" class="text-center text-muted py-4">No hay eventos reproductivos registrados.</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>
