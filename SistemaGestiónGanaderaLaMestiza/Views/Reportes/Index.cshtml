@{
    ViewBag.Title = "Reportes";
    var inventario = ViewBag.Inventario as System.Collections.Generic.IList<SistemaGestiónGanaderaLaMestiza.Models.ReporteInventarioItem>;
    var distribucion = ViewBag.DistribucionSalud as System.Collections.Generic.IList<SistemaGestiónGanaderaLaMestiza.Models.DistribucionSalud>;
    var potreros = ViewBag.Potreros as System.Collections.Generic.IList<SistemaGestiónGanaderaLaMestiza.Models.Potrero>;
}
<div class="page-header">
    <div>
        <h2 class="mb-1">Reportes</h2>
        <p class="text-muted mb-0">Analiza inventario y salud del ganado con filtros rapidos.</p>
    </div>
    @Html.ActionLink("Exportar CSV", "Exportar", "Reportes", new { raza = Request.QueryString["raza"], id_potrero = Request.QueryString["id_potrero"], id_finca = Request.QueryString["id_finca"], salud = Request.QueryString["salud"], rango_edad = Request.QueryString["rango_edad"] }, new { @class = "btn btn-outline-secondary" })
</div>

<div class="surface-card mb-3">
    @using (Html.BeginForm("Index", "Reportes", FormMethod.Get))
    {
        <div class="filter-grid">
            <input type="text" name="raza" class="form-control form-control-sm" placeholder="Raza" value="@Request.QueryString["raza"]" />
            <select name="id_potrero" class="form-select form-select-sm">
                <option value="">Potrero</option>
                @if (potreros != null)
                {
                    foreach (var p in potreros)
                    {
                        <option value="@p.IdPotrero" @(Request.QueryString["id_potrero"] == p.IdPotrero.ToString() ? "selected" : "")>@p.Nombre</option>
                    }
                }
            </select>
            <input type="text" name="salud" class="form-control form-control-sm" placeholder="Salud" value="@Request.QueryString["salud"]" />
            <select name="rango_edad" class="form-select form-select-sm">
                <option value="">Edad</option>
                <option value="Cachorro" @(Request.QueryString["rango_edad"] == "Cachorro" ? "selected" : "")>Cachorro (&lt;1)</option>
                <option value="Juvenil" @(Request.QueryString["rango_edad"] == "Juvenil" ? "selected" : "")>Juvenil (1-3)</option>
                <option value="Adulto" @(Request.QueryString["rango_edad"] == "Adulto" ? "selected" : "")>Adulto (3-10)</option>
                <option value="Anciano" @(Request.QueryString["rango_edad"] == "Anciano" ? "selected" : "")>Anciano (&gt;10)</option>
            </select>
        </div>
        <div class="mt-3 d-flex gap-2">
            <button type="submit" class="btn btn-sm btn-secondary">Filtrar</button>
            <a href="@Url.Action("Index", "Reportes")" class="btn btn-sm btn-outline-secondary">Limpiar</a>
        </div>
    }
</div>

<div class="surface-card table-card mb-3">
    <h3 class="section-title">Inventario filtrado</h3>
    <div class="table-responsive">
        <table class="table table-hover">
            <thead><tr><th>Nombre</th><th>Raza</th><th>Sexo</th><th>Tipo</th><th>Salud</th><th>Potrero</th><th>Edad</th></tr></thead>
            <tbody>
                @if (inventario != null && inventario.Count > 0)
                {
                    foreach (var i in inventario)
                    {
                        <tr><td>@i.Nombre</td><td>@i.Raza</td><td>@i.Sexo</td><td>@i.Tipo</td><td>@i.Salud</td><td>@i.NombrePotrero</td><td>@i.Edad</td></tr>
                    }
                }
                else
                {
                    <tr><td colspan="7" class="text-center text-muted py-4">No hay datos para los filtros seleccionados.</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>

<div class="surface-card table-card">
    <h3 class="section-title">Distribucion por salud</h3>
    <div class="table-responsive">
        <table class="table table-hover">
            <thead><tr><th>Salud</th><th>Cantidad</th></tr></thead>
            <tbody>
                @if (distribucion != null && distribucion.Count > 0)
                {
                    foreach (var d in distribucion)
                    {
                        <tr><td>@d.Salud</td><td>@d.Cantidad</td></tr>
                    }
                }
                else
                {
                    <tr><td colspan="2" class="text-center text-muted py-4">Sin informacion de salud.</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>
